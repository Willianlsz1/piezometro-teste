# ─────────────────────────────────────────────────────────────────────────────
# Arquivo de exemplo para variáveis de ambiente.
# Copie este arquivo para ".env" e preencha os valores reais.
# NUNCA commite o arquivo ".env" no git — adicione-o ao .gitignore!
# ─────────────────────────────────────────────────────────────────────────────

# Porta local do servidor (padrão: 3000)
PORT=3000

# URL base do InfluxDB Cloud
INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com

# Token de autenticação do InfluxDB (OBRIGATÓRIO — nunca coloque no código!)
# Dica de segurança: use um token SOMENTE LEITURA restrito ao bucket PIEZOMETRO
INFLUX_TOKEN=seu_token_aqui

# Organização no InfluxDB
INFLUX_ORG=SAMARCO

# Origem permitida pelo CORS (use "*" em dev, o domínio real em produção)
# Exemplo produção: ALLOWED_ORIGIN=https://SEU-USUARIO.github.io
ALLOWED_ORIGIN=*

# Único bucket que o proxy aceita consultar (padrão: PIEZOMETRO)
ALLOWED_BUCKET=PIEZOMETRO

# ── ALERTAS ATIVOS (nível d'água) ────────────────────────────────────────────
# Limiares em metros — espelhados no firmware e no dashboard
NIVEL_ATENCAO=12
NIVEL_CRITICO=15
# Intervalo de verificação (s) e reenvio do crítico (min)
ALERT_POLL_SEC=60
ALERT_REPEAT_MIN=15

# Telegram (gratuito): crie um bot com o @BotFather e pegue o chat_id
# em https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMS via Twilio (opcional, pago) — números no formato E.164 (+55...)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# ── INGESTÃO (placa → servidor) ──────────────────────────────────────────────
# Token de ESCRITA do InfluxDB, usado só pelo /ingest (a placa nunca vê este
# token). Pode ser diferente do INFLUX_TOKEN — este último pode ficar somente
# leitura, já que quem escreve agora é o servidor.
INFLUX_WRITE_TOKEN=

# Chave compartilhada que a placa envia no header "x-device-key" ao chamar
# /ingest. Deixe vazia apenas em desenvolvimento (o endpoint fica sem
# autenticação); em produção, defina um valor forte e replique no firmware.
DEVICE_KEY=
