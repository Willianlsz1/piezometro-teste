# ─────────────────────────────────────────────────────────────────────────────
# Arquivo de exemplo para variáveis de ambiente.
# Copie este arquivo para ".env" e preencha os valores reais.
# NUNCA commite o arquivo ".env" no git — adicione-o ao .gitignore!
# ─────────────────────────────────────────────────────────────────────────────

# Porta local do servidor (padrão: 3000)
PORT=3000

# URL base do InfluxDB Cloud
INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com

# Token de autenticação do InfluxDB (OBRIGATÓRIO — nunca coloque no código!)
INFLUX_TOKEN=seu_token_aqui

# Organização no InfluxDB
INFLUX_ORG=SAMARCO

# Origem permitida pelo CORS (use "*" em dev, o domínio real em produção)
# Exemplo produção: ALLOWED_ORIGIN=https://piezometro-teste-production.up.railway.app
ALLOWED_ORIGIN=*
