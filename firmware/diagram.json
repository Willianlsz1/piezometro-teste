{
  "version": 1,
  "author": "Projeto Samarco — SENAI",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    {
      "type": "board-bmp180",
      "id": "bmp180",
      "top": -120,
      "left": 180,
      "attrs": { "pressure": "101325", "temperature": "24" }
    },
    { "type": "board-ssd1306", "id": "oled", "top": -120, "left": 340, "attrs": { "i2cAddress": "0x3c" } },
    { "type": "wokwi-led", "id": "led_verde", "top": 180, "left": 220, "attrs": { "color": "green" } },
    { "type": "wokwi-led", "id": "led_amarelo", "top": 180, "left": 280, "attrs": { "color": "yellow" } },
    { "type": "wokwi-led", "id": "led_vermelho", "top": 180, "left": 340, "attrs": { "color": "red" } },
    { "type": "wokwi-resistor", "id": "r1", "top": 260, "left": 220, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r2", "top": 260, "left": 280, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r3", "top": 260, "left": 340, "attrs": { "value": "220" } },
    { "type": "wokwi-buzzer", "id": "bz1", "top": 180, "left": 420, "attrs": { "volume": "0.1" } }
  ],
  "connections": [
    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],

    [ "bmp180:VCC", "esp:3V3", "red", [] ],
    [ "bmp180:GND", "esp:GND.1", "black", [] ],
    [ "bmp180:SCL", "esp:22", "yellow", [] ],
    [ "bmp180:SDA", "esp:21", "green", [] ],

    [ "oled:VCC", "esp:3V3", "red", [] ],
    [ "oled:GND", "esp:GND.1", "black", [] ],
    [ "oled:SCL", "esp:22", "yellow", [] ],
    [ "oled:SDA", "esp:21", "green", [] ],

    [ "esp:32", "led_verde:A", "green", [] ],
    [ "led_verde:C", "r1:1", "green", [] ],
    [ "r1:2", "esp:GND.2", "black", [] ],

    [ "esp:33", "led_amarelo:A", "gold", [] ],
    [ "led_amarelo:C", "r2:1", "gold", [] ],
    [ "r2:2", "esp:GND.2", "black", [] ],

    [ "esp:25", "led_vermelho:A", "red", [] ],
    [ "led_vermelho:C", "r3:1", "red", [] ],
    [ "r3:2", "esp:GND.2", "black", [] ],

    [ "esp:26", "bz1:1", "orange", [] ],
    [ "bz1:2", "esp:GND.2", "black", [] ]
  ],
  "dependencies": {}
}
